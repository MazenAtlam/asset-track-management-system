                  "pm.test(\"Status is 400 Bad Request\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "pm.test(\"Response matches strict error contract\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.error).to.exist;\r",
                  "    pm.expect(jsonData.message).to.be.undefined; // Ensures old format is gone\r",
                  "});"
                ],
